{
  "name": "@mcphosting/cli",
  "version": "1.0.0",
  "description": "Deploy and manage MCP servers from the terminal. The easiest way to host MCP servers.",
  "bin": {
    "mcphosting": "./dist/index.js",
    "mcphost": "./dist/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node dist/index.js --help"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "chatgpt",
    "cursor",
    "ai-agents",
    "mcp-server",
    "mcp-hosting",
    "mcp-deploy",
    "mcp-marketplace",
    "ai-tools",
    "llm-tools",
    "deploy",
    "hosting"
  ],
  "author": "MCPHosting",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "open": "^10.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
